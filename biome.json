{
    "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
    "formatter": {
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 120,
        "lineEnding": "lf"
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "semicolons": "always",
            "arrowParentheses": "asNeeded"
        }
    },
    "assist": {
        "actions": {
            "source": {
                "organizeImports": {
                    "level": "on",
                    "options": {
                        "groups": [":PACKAGE:", ":BLANK_LINE:", ":NODE:", ":BLANK_LINE:", ":BLANK_LINE:", ":PATH:"]
                    }
                }
            }
        }
    }
}
